[Unit]
Description=SIDITA Gunicorn service
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/srv/sidita
Environment="PATH=/srv/sidita/venv/bin"
ExecStart=/srv/sidita/venv/bin/gunicorn -w 4 -b 0.0.0.0:8000 wsgi:app
Restart=on-failure

[Install]
WantedBy=multi-user.target
